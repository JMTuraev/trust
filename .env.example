# Server
PORT=3000

# Supabase (Dashboard -> Settings -> API)
SUPABASE_URL=https://cgqudcbvezwxjxgaqdiw.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Ilova sessiya tokenlari uchun maxfiy kalit (kuchli tasodifiy qiymat)
# Yaratish: openssl rand -hex 32
APP_JWT_SECRET=your_random_secret

# DevSMS (devsms.uz -> Dashboard -> API token)
DEVSMS_TOKEN=your_devsms_token
# Eskiz universal OTP shablonidagi servis nomi
SMS_SERVICE_NAME=AllClubs
# 1=Amaliyot tasdiqlash, 2=Parol tiklash, 3=Ro'yxatdan o'tish, 4=Tizimga kirish
SMS_TEMPLATE_TYPE=4

# OTP sozlamalari
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# STT (ovoz -> matn), XOTIRA-ovoz-va-kategoriya.md bo'yicha
# Asosiy: Groq (console.groq.com -> API Keys, bepul tarif: kuniga 2000 so'rov)
